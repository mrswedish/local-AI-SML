      "Bash(npm run dev)",
      "Bash(grep -v \"^$\")",
      "Bash(grep -v \"Building\\\\|Compiling\\\\|DEPRECATION\\\\|sass\\\\|scss\\\\|node_modules\\\\|katex\\\\|^$\")",
