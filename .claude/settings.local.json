      "Bash(powershell.exe -Command \"Stop-Process -Name loke -Force -ErrorAction Ignore; Stop-Process -Name ''loke-lib'' -Force -ErrorAction Ignore\")",
      "Bash(powershell.exe -Command \"Get-Process loke -ErrorAction SilentlyContinue | Select-Object Name,Id,CPU\")",
      "Bash(powershell.exe -Command \"Get-Process loke -ErrorAction SilentlyContinue | Select-Object Id, StartTime, CPU\")"
