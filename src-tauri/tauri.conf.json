{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loke",
  "version": "2.1.1",
  "identifier": "com.loke.app",
  "build": {
    "beforeDevCommand": "npm --prefix webui run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix webui run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Loke – Lokal kontext expert",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}